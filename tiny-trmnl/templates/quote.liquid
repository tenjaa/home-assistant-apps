<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://trmnl.com/css/2.3.7/plugins.css">
    <script src="https://trmnl.com/js/2.3.7/plugins.js"></script>
</head>
<body class="environment trmnl">
<div class="screen">
    <div class="view view--full">
        <div class="layout">
            <div class="columns">
                <div class="column">
                    <div class="markdown">
                        <span class="title">{{ title }}</span>
                        <div class="content content--center">"{{ quote }}"</div>
                        <span class="label label--underline">{{ author }}</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="title_bar">
            <span class="title">Quote</span>
            <span class="instance">{{ instance_id }}</span>
        </div>
    </div>
</div>
</body>
</html>

